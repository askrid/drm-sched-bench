#version 450
layout(local_size_x = 64) in;
layout(push_constant) uniform PC { uint loops; };
layout(set = 0, binding = 0) buffer Buf { uint data[]; };
void main() {
    uint idx = gl_GlobalInvocationID.x;
    uint val = data[idx];
    for (uint i = 0; i < loops; i++)
        val = val * 1103515245u + 12345u;
    data[idx] = val;
}
